{
  "expo": {
    "name": "Mentis",
    "slug": "mentis",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "dark",
    "scheme": "mentis",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "splash": {
      "backgroundColor": "#0A0A0F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mentis.app",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0F",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.mentis.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single"
    },
    "extra": {
      "appwriteEndpoint": "https://sgp.cloud.appwrite.io/v1",
      "appwriteProjectId": "6a4e2a05001fe75eb314",
      "apiUrl": "https://mentis-api-t9hk.onrender.com",
      "router": {},
      "eas": {
        "projectId": "e573f2d7-3a22-483c-b090-3f12c50a4026"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Mentis needs camera access to scan problems."
        }
      ],
      [
        "expo-sensors",
        {
          "motionPermission": "Mentis needs motion access for AR tracking."
        }
      ]
    ],
    "owner": "vshar_ma67"
  }
}
