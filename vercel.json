{
  "installCommand": "cd mobile && npm install",
  "buildCommand": "cd mobile && npx expo export --platform web",
  "outputDirectory": "mobile/dist",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/_expo/:path*",
      "destination": "/_expo/:path*"
    },
    {
      "source": "/assets/:path*",
      "destination": "/assets/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
